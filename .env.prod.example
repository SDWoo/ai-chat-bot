# 프로덕션 배포용 환경 변수
# 복사 후 .env로 저장하고 값을 채우세요: cp .env.prod.example .env

# 필수
OPENAI_API_KEY=your-openai-api-key
POSTGRES_PASSWORD=strong-password-here
JWT_SECRET_KEY=random-32-char-secret-key-here

# 선택 (기본값 사용 가능)
POSTGRES_USER=chatbot
POSTGRES_DB=chatbot
PORT=80

# Microsoft OAuth (선택)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=https://your-domain.com/api/auth/callback
FRONTEND_URL=https://your-domain.com
CORS_ORIGINS='["https://your-domain.com"]'
